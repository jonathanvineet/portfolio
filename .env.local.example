# Copy this file to `.env.local` and replace the placeholder values with your actual credentials
# DO NOT commit .env.local to version control - it contains sensitive information

# ============================================================================
# SUPABASE CONFIGURATION (Required for storing contact messages)
# ============================================================================
# Get these from: https://app.supabase.com -> Project Settings -> API Keys

# Your Supabase project URL
# Example: https://fwbvvdduuzcheibmjrhn.supabase.co
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url_here

# Your Supabase anonymous/public key (safe to expose)
# Example: eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
NEXT_PUBLIC_SUPABASE_KEY=your_supabase_public_key_here

# Your Supabase service role key (KEEP THIS SECRET - server-side only)
# Example: eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# ============================================================================
# EMAIL CONFIGURATION (Optional but recommended)
# ============================================================================
# If not set, messages will still be saved to Supabase but email notifications won't be sent

# SMTP Server settings
# For Gmail: smtp.gmail.com
# For SendGrid: smtp.sendgrid.net
# For Outlook: smtp-mail.outlook.com
EMAIL_HOST=smtp.gmail.com

# SMTP Port (typically 587 for TLS, 465 for SSL)
EMAIL_PORT=587

# Use secure connection (true for port 465, false for port 587)
EMAIL_SECURE=false

# Your email address
# For Gmail: your-email@gmail.com
# For SendGrid: apikey (username is literally "apikey")
EMAIL_USER=your-email@gmail.com

# Your email password or API key
# For Gmail: Use App Password (NOT your regular password)
#   1. Enable 2FA on your Google account
#   2. Go to https://myaccount.google.com/apppasswords
#   3. Select Mail and Windows Computer
#   4. Copy the 16-character password
# For SendGrid: Your API key starting with SG.
EMAIL_PASSWORD=your_16_character_app_password

# Email address where you want to receive contact form notifications
# (Can be the same as EMAIL_USER or different)
CONTACT_EMAIL_RECIPIENT=your-email@gmail.com

# ============================================================================
# GITHUB CONFIGURATION
# ============================================================================
NEXT_PUBLIC_GITHUB_USERNAME=jonathanvineet

# ============================================================================
# ADMIN API CONFIGURATION (Optional)
# ============================================================================
# Set this to protect the /api/messages endpoint with a secret token
# If not set, the endpoint is open (make sure you implement other auth)
# Example: supersecrettoken123
# ADMIN_API_SECRET=your_secret_token_here
