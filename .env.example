# GitHub Configuration (for fetching software projects)
NEXT_PUBLIC_GITHUB_USERNAME=jonathanvineet
# Optional: GitHub token for higher rate limits (5000 requests/hour vs 60)
# NEXT_PUBLIC_GITHUB_TOKEN=your_github_personal_access_token

# Supabase Configuration (for hardware projects and contact messages)
NEXT_PUBLIC_SUPABASE_KEY=your_supabase_anon_key
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Email Configuration (for contact form notifications)
# Supports any SMTP service (Gmail, SendGrid, etc.)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your_email@gmail.com
EMAIL_PASSWORD=your_app_password
CONTACT_EMAIL_RECIPIENT=your_email@gmail.com
